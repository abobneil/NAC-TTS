COMPOSE_PROJECT_NAME=nac_tts
APP_HOST=localhost
APP_PORT=8080
API_PORT=8000
REDIS_PORT=6379
TTS_MODEL_ID=hexgrad/Kokoro-82M
KOKORO_LANG_CODE=a
KOKORO_DEVICE=cuda
KOKORO_VOICES=af_heart,af_bella,am_adam,bf_emma,bm_george
MAX_UPLOAD_MB=25
MAX_PAGES=100
MAX_CHARS=80000
MAX_ACTIVE_JOBS=2
MAX_JOB_RETRIES=2
QUEUE_NAME=tts:jobs
DATABASE_URL=sqlite:////data/db/nac_tts.sqlite3
REDIS_URL=redis://redis:6379/0
STORAGE_ROOT=/data
APP_ACCESS_TOKEN=replace-with-a-long-random-token
AUTH_SESSION_SECRET=replace-with-a-different-long-random-secret
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_SECONDS=43200
CORS_ALLOW_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
AUDIO_BASE_URL=/api/v1/jobs
CF_TUNNEL_HOSTNAME=tts.example.com
CF_TUNNEL_ID=
CF_TUNNEL_CREDENTIALS=/etc/cloudflared/credentials.json
CF_ACCESS_AUDIENCE=
